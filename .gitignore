# ───────────────────────────────────────────────────────────────
# Jupyter
# ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*-checkpoint.ipynb

# ───────────────────────────────────────────────────────────────
# Secrets / API keys — NEVER commit these
# ───────────────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
credentials.json
config.local.*
**/anthropic_key*
**/*_api_key*
**/*.key

# ───────────────────────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ───────────────────────────────────────────────────────────────
# Virtual environments
# ───────────────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# ───────────────────────────────────────────────────────────────
# Testing / coverage
# ───────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache
nosetests.xml
coverage.xml

# ───────────────────────────────────────────────────────────────
# Editors / OS
# ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ───────────────────────────────────────────────────────────────
